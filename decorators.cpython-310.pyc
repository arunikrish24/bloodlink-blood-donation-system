<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Blood Link Login</title>
  {% comment %} <link href="https://unicons.iconscout.com/release/v4.0.0/css/line.css" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;500;600&display=swap" rel="stylesheet"> {% endcomment %}
  <!-- Toastify -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/toastify-js/src/toastify.min.css">
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
      font-family: 'Poppins', sans-serif;
    }

    body {
      background: #f8f9fa;
      display: flex;
      justify-content: center;
      align-items: center;
      min-height: 100vh;
    }

    .login-container {
      background-color: #fff;
      padding: 40px 30px;
      border-radius: 12px;
      box-shadow: 0 8px 24px rgba(0, 0, 0, 0.1);
      width: 100%;
      max-width: 400px;
    }

    .login-header {
      text-align: center;
      margin-bottom: 30px;
    }

    .login-header i {
      font-size: 48px;
      color: #c0392b;
      margin-bottom: 10px;
    }

    .login-header h2 {
      font-weight: 600;
      color: #2c3e50;
    }

    .login-header p {
      font-size: 14px;
      color: #555;
    }

    .form-group {
      margin-bottom: 20px;
      position: relative;
    }

    .form-group input {
      width: 100%;
      padding: 12px 40px 12px 16px;
      border-radius: 8px;
      border: 1px solid #ccc;
      outline: none;
      transition: border-color 0.3s;
    }

    .form-group input:focus {
      border-color: #c0392b;
    }

    .form-group i {
      position: absolute;
      top: 50%;
      right: 16px;
      transform: translateY(-50%);
      color: #888;
    }

    .login-button {
      background-color: #c0392b;
      color: #fff;
      border: none;
      width: 100%;
      padding: 12px;
      border-radius: 8px;
      font-weight: 500;
      cursor: pointer;
      transition: background 0.3s;
    }

    .login-button:hover {
      background-color: #a93226;
    }

    .options {
      display: flex;
      justify-content: space-between;
      align-items: center;
      font-size: 13px;
      margin-top: 12px;
    }

    .options label {
      display: flex;
      align-items: center;
      gap: 6px;
      cursor: pointer;
    }

    .options a {
      color: #c0392b;
      text-decoration: none;
    }

    .options a:hover {
      text-decoration: underline;
    }

    .signup-link {
      text-align: center;
      margin-top: 25px;
      font-size: 13px;
    }

    .signup-link a {
      color: #c0392b;
      text-decoration: none;
      font-weight: 500;
    }

    .signup-link a:hover {
      text-decoration: underline;
    }

    @media (max-width: 480px) {
      .login-container {
        padding: 30px 20px;
      }

      .login-header i {
        font-size: 40px;
      }
    }
  </style>
</head>
<body>

  <div class="login-container" role="form" aria-labelledby="login-title">
    <div class="login-header">
      <i class="uil uil-drop"></i>
      <h2 id="login-title">Login</h2>
      <p>Your account for donating blood & saving lives</p>
    </div>
    {% if messages %}
      {% for msg in messages %}
        <p style="color:red">{{ msg }}</p>
      {% endfor %}
    {% endif %}
    <form method="post">
      {% csrf_token %}
      <div class="form-group">
        <input type="email" placeholder="Email address" aria-label="email" name="email" required />
        <i class="uil uil-envelope"></i>
      </div>
      <div class="form-group">
        <input type="password" placeholder="Password" aria-label="password" name="password" required />
        <i class="uil uil-lock"></i>
      </div>

      <div class="options">
        <label>
          <input type="checkbox" />
          Remember me
        </label>
        <a href="{% url 'forgot_password' %}">Forgot password?</a>
      </div>

      <button type="submit" class="login-button">Login</button>
    </form>

    <div class="signup-link">
      New to our blood bank? <a href="/">Register as Donor</a>
    </div>
  </div>

  {% if messages %}
<script>
    document.addEventListener("DOMContentLoaded", function () {
        {% for message in messages %}
        Toastify({
            text: "{{ message|escapejs }}",
            duration: 5000,
            gravity: "top",
            position: "right",
            backgroundColor: "{% if message.tags == 'success' %}#28a745{% elif message.tags == 'error' %}#dc3545{% elif message.tags == 'warning' %}#ffc107{% else %}#17a2b8{% endif %}",
            stopOnFocus: true,
            style: {
                borderRadius: "8px",
                boxShadow: "0 2px 8px rgba(0,0,0,0.2)",
                fontSize: "15px"
            }
        }).showToast();
        {% endfor %}
    });
</script>
{% endif %}

</body>
</html>
