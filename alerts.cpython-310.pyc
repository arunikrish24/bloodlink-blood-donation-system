<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>BloodBank | Donate Blood, Save Lives</title>
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />

    <link
      href="https://unicons.iconscout.com/release/v4.0.0/css/line.css"
      rel="stylesheet"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;500;600&display=swap"
      rel="stylesheet"
    />
    <style>
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
        font-family: "Poppins", sans-serif;
      }

      body {
        background-color: #f8f9fa;
        color: #2c3e50;
      }

      header {
        background-color: #c0392b;
        padding: 20px 40px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        color: #fff;
      }

      header h1 {
        font-size: 24px;
      }

      nav a {
        margin-left: 25px;
        text-decoration: none;
        color: #fff;
        font-weight: 500;
      }

      nav a:hover {
        text-decoration: underline;
      }

      .hero {
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
        padding: 80px 20px 40px;
        background-color: #fff;
      }

      .hero h2 {
        font-size: 36px;
        color: #c0392b;
        margin-bottom: 20px;
      }

      .hero p {
        max-width: 600px;
        font-size: 18px;
        margin-bottom: 30px;
      }

      .hero .buttons {
        display: flex;
        gap: 20px;
        flex-wrap: wrap;
      }

      .hero .buttons a {
        text-decoration: none;
        background-color: #c0392b;
        color: #fff;
        padding: 12px 24px;
        border-radius: 8px;
        font-weight: 500;
        transition: background 0.3s;
      }

      .hero .buttons a:hover {
        background-color: #a93226;
      }

      .about,
      .how-it-works,
      .cta {
        padding: 60px 20px;
        text-align: center;
        background-color: #fff;
      }

      .about h3,
      .how-it-works h3 {
        font-size: 28px;
        color: #c0392b;
        margin-bottom: 20px;
      }

      .about p,
      .how-it-works p {
        max-width: 700px;
        margin: 0 auto 20px;
        font-size: 16px;
        line-height: 1.6;
      }

      .steps {
        display: flex;
        justify-content: center;
        gap: 30px;
        flex-wrap: wrap;
        margin-top: 30px;
      }

      .step {
        max-width: 200px;
        background-color: #f1f1f1;
        padding: 20px;
        border-radius: 10px;
      }

      .step i {
        font-size: 30px;
        color: #c0392b;
        margin-bottom: 10px;
      }

      .step p {
        font-size: 14px;
      }

      .cta {
        background-color: #fdf0f0;
      }

      .cta h4 {
        font-size: 24px;
        margin-bottom: 20px;
        color: #c0392b;
      }

      .cta a {
        text-decoration: none;
        background-color: #c0392b;
        color: #fff;
        padding: 12px 24px;
        border-radius: 8px;
        font-weight: 500;
        transition: background 0.3s;
      }

      .cta a:hover {
        background-color: #a93226;
      }

      footer {
        text-align: center;
        padding: 20px;
        background-color: #c0392b;
        color: #fff;
        font-size: 14px;
      }

      @media (max-width: 768px) {
        .hero h2 {
          font-size: 28px;
        }
        .about,
        .how-it-works,
        .cta {
          padding: 40px 20px;
        }
        .steps {
          flex-direction: column;
          align-items: center;
        }
      }

      .nav-links {
        display: flex;
        align-items: center;
        gap: 20px;
      }

      .nav-links a {
        color: #fff;
        text-decoration: none;
        font-weight: 500;
        position: relative;
      }

      .nav-links a:hover {
        text-decoration: underline;
      }

      .dropdown-nav {
        position: relative;
      }

      .dropdown-nav .dropdown-content {
        display: none;
        position: absolute;
        background-color: #fff;
        color: #333;
        min-width: 140px;
        box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
        z-index: 1000;
        border-radius: 4px;
        top: 100%;
        left: 0;
        padding: 8px 0;
      }

      .dropdown-nav .dropdown-content li {
        list-style: none;
      }

      .dropdown-nav .dropdown-content a {
        color: #c0392b;
        padding: 10px 20px;
        display: block;
        text-decoration: none;
        font-weight: 500;
      }

      .dropdown-nav .dropdown-content a:hover {
        background-color: #f5f5f5;
      }

      .dropdown-nav:hover .dropdown-content {
        display: block;
      }
    </style>
  </head>
  <body>
    <header>
      <h1><i class="uil uil-drop"></i> BloodLink</h1>
      <nav class="nav-links">
        <a href="/">Home</a>
        <a href="/#about">About</a>
        <a href="/#how">How It Works</a>
        <a href="{% url 'login' %}">Login</a>

        <div class="dropdown-nav">
          <a
            href="#"
            class="nav-link dropdown-toggle"
            id="registerMenu"
            role="button"
          >
            Register
          </a>
          <ul class="dropdown-content">
            <li><a href="{% url 'donor-register' %}">Donor</a></li>
            <li><a href="{% url 'bloodbank-register' %}">Blood Bank</a></li>
            <li><a href="{% url 'rcc-register' %}">RCC</a></li>
          </ul>
        </div>
      </nav>
    </header>

    <section>
      {% block content %} 
      {% endblock %}
    </section>

    <footer>&copy; 2025 BloodBank. Designed with ❤️ to save lives.</footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  </body>
</html>
