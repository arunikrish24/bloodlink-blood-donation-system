{% load static %}
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>BloodBank | Donate Blood, Save Lives</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet"/>
  <link href="https://unicons.iconscout.com/release/v4.0.0/css/line.css" rel="stylesheet"/>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;500;600&display=swap" rel="stylesheet"/>
  <style>
    html, body {
      min-height: 100%;
      background: linear-gradient(to bottom, #dc3545, #c82333 120%);
      color: #fff;
      font-family: 'Poppins', sans-serif;
      scroll-behavior: smooth;
    }
    header {
      background: rgba(220, 53, 69, 0.96);
      padding: 24px 40px 16px;
      display: flex;
      justify-content: space-between;
      align-items: center;
      border-bottom: 1px solid rgba(255,255,255,0.13);
      box-shadow: 0 4px 28px rgba(220,53,69,.11);
      position: sticky;
      top: 0; z-index: 20;
    }
    header h1 {
      display: flex;
      align-items: center;
      font-size: 2rem;
      letter-spacing: 1px;
      font-weight: 700;
      margin: 0;
      gap: 8px;
    }
    nav.nav-links {
      display: flex;
      align-items: center;
      gap: 18px;
      font-size: 1.08rem;
    }
    .nav-links a,
    .dropdown-nav > a {
      color: #fff;
      text-decoration: none;
      padding: 6px 18px;
      border-radius: 6px;
      transition: background .17s;
      font-weight: 500;
      position: relative;
    }
    .nav-links a:hover,
    .dropdown-nav > a:hover {
      background: rgba(255,255,255,0.13);
      color: #fff;
    }
    .dropdown-nav {
      position: relative;
    }
    .dropdown-content {
      display: none;
      position: absolute;
      background: #fff;
      color: #c0392b;
      min-width: 150px;
      box-shadow: 0 8px 24px rgba(32,32,32,.18);
      border-radius: 7px;
      z-index: 1005;
      top: 32px;
      animation: fadeInDown .25s;
    }
    .dropdown-content li { list-style: none; }
    .dropdown-content a {
      color: #c0392b;
      font-weight: 500;
      padding: 11px 20px; 
      display: block;
      border-radius: 7px;
      transition: background .15s;
      text-decoration: none;
    }
    .dropdown-content a:hover { color:rgb(228, 82, 66); }
    .dropdown-nav:hover .dropdown-content, .dropdown-nav:focus-within .dropdown-content {
      display: block;
    }
    /* --- Hero Section --- */
    .hero {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 70px 6vw;
  background: linear-gradient(120deg, #fff 50%,rgb(255, 255, 255) 100%);
  color: #222;
}

.hero-content {
  min-height: 60dvh; 
  display: flex;
  flex-wrap: wrap;
  gap: 40px;
  align-items: center;
  max-width: 1100px;
  background: linear-gradient(120deg, #fff 50%,rgb(255, 255, 255) 100%);
}

.hero-text {
  flex: 1 1 420px;
}

.hero h2 {
  font-size: 2.6rem;
  font-weight: 700;
  color: #b11930;
  margin-bottom: 15px;
}

.hero p {
  font-size: 1.2rem;
  color: #444;
  margin-bottom: 25px;
  max-width: 500px;
}

.hero .buttons {
  display: flex;
  gap: 18px;
  flex-wrap: wrap;
}

.hero .buttons a {
  padding: 13px 34px;
  border-radius: 30px;
  font-weight: 600;
  text-decoration: none;
  transition: 0.25s;
}

.hero .buttons .primary-btn {
  background: #dc3545;
  color: #fff;
  box-shadow: 0 6px 20px rgba(220, 53, 69, 0.25);
}

.hero .buttons .primary-btn:hover {
  background: #b11930;
  transform: translateY(-2px);
}

.hero .buttons .secondary-btn {
  border: 2px solid #dc3545;
  color: #dc3545;
  background: transparent;
}

.hero .buttons .secondary-btn:hover {
  background: #f8d7da;
}

.hero-img {
  flex: 1 1 360px;
  display: flex;
  justify-content: center;
}

.hero-img img {
  width: 100%;
  max-width: 600px;
  border-radius: 15px;
}

    .about, .how-it-works, .cta {
      padding: 64px 10vw 60px;
      text-align: center;
      background: #fff;
      color: #b52c3e;
      position: relative;
    }
    .about{ animation: fadeInUp 1.1s;}
    .how-it-works{ animation: fadeInUp 1.3s;}
    @keyframes fadeInUp {
      from {opacity: 0; transform: translateY(40px);}
      to   {opacity: 1; transform: translateY(0);}
    }
    .about h3, .how-it-works h3 {
      font-size: 2rem;
      color: #b52c3e;
      margin-bottom: 17px;
      font-weight: 700;
      letter-spacing: .5px;
    }
    .about p, .how-it-works p {
      max-width: 780px;
      margin: 0 auto 18px;
      font-size: 1.11rem;
      color: #65242f;
      line-height: 1.56;
    }
    /* --- Image/Illustration block for About --- */
    .about .section-img {
    width: 100%;
    height: 250px; /* adjust for slim banner height */
    overflow: hidden;
    border-radius: 0; /* makes it a clean edge banner */
    animation: fadeInZoom .97s;
  }

  .about .section-img img {
    width: 100%;
    height: 100%;
    object-fit:contain;
    display: block;
  }


    /* --- Steps section --- */
    .steps {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(190px, 1fr));
      gap: 36px;
      margin-top: 39px;
      justify-content: center;
      align-items: start;
    }
    .step {
      background: linear-gradient(135deg, #f9dede 37%, #ffe8e8 100%);
      padding: 28px 14px;
      border-radius: 14px;
      box-shadow: 0 2px 16px 0 rgba(180,45,63,0.07);
      min-height: 170px;
      display: flex;
      flex-direction: column;
      align-items: center;
      transition: transform 0.13s, box-shadow 0.13s;
      animation: fadeInUpStep .7s;
    }
    @keyframes fadeInUpStep {
      from {opacity: 0; transform: translateY(16px);}
      to   {opacity: 1; transform: translateY(0);}
    }
    .step i { font-size: 40px; color: #d42b44; margin-bottom: 12px;}
    .step p { font-size: 1.04rem; color: #a03141;}
    /* --- CTA --- */
    .cta {
      background: linear-gradient(90deg, #ffe8e8 60%, #ffdbdb);
      color: #c82333;
      border-top: 1px solid #ffeaea;
    }
    .cta h4 {
      font-size: 2rem;
      font-weight: 600;
      margin-bottom: 18px;
      margin-top: 0;
      color: #c82333;
      letter-spacing: 0.5px;
    }
    .cta a {
      background: linear-gradient(90deg, #dc3545 60%, #c82333);
      color: #fff;
      padding: 13px 35px;
      border-radius: 28px;
      font-weight: 700;
      margin-top: 10px;
      display: inline-block;
      font-size: 1.15rem;
      text-decoration: none;
      box-shadow: 0 8px 37px 0 rgba(220,53,69,0.18);
      transition: background .17s, color .17s, transform .16s;
    }
    /* --- Responsive --- */
    @media (max-width: 850px) {
      .about, .how-it-works, .cta { padding: 40px 6vw;}
      header { flex-direction: column; gap: 6px; padding: 18px 2vw;}
      .steps { gap: 22px; }
      .hero h2{ font-size: 2.05rem;}
      .hero { padding: 60px 2vw 22px;}
    }
    @media (max-width: 580px) {
      .about .section-img { width: 92vw;}
      .hero .hero-img{ width: 94vw;}
      .step { min-width: 80vw;}
      header h1 { font-size: 1.25rem;}
      .hero h2 { font-size: 1.25rem;}
      .about h3, .how-it-works h3 { font-size: 1.2rem;}
      .steps { grid-template-columns: 1fr;}
    }
    footer {
      text-align: center; 
      padding: 20px 3vw;
      background: rgba(220,53,69,0.98);
      color: #fff; font-size: 1rem;
      letter-spacing: .8px;
      margin-bottom: 0;
      margin-top: 0;
      border-top: 1px solid #fff1;
      box-shadow: 0 -2px 24px 0 rgba(220,53,69,0.1);
    }
    /* Animations for scrolling (uses intersection observer below) */
    .animate-fade-up { opacity: 0; transform: translateY(48px); transition: opacity 0.7s, transform 0.7s;}
    .animate-fade-up.in-view { opacity: 1; transform: none;}
  </style>
</head>
<body>
  <header>
    <h1><i class="uil uil-drop"></i> BloodLink</h1>
    <nav class="nav-links">
      <a href="#">Home</a>
      <a href="#about">About</a>
      <a href="#how">How It Works</a>
      <a href="{% url 'login' %}">Login</a>
      <div class="dropdown-nav">
        <a href="#" class="nav-link dropdown-toggle" id="registerMenu">Register</a>
        <ul class="dropdown-content">
          <li><a href="{% url 'donor-register' %}">Donor</a></li>
          <li><a href="{% url 'bloodbank-register' %}">Blood Bank</a></li>
          <li><a href="{% url 'rcc-register' %}">RCC</a></li>
        </ul>
      </div>
    </nav>
  </header>
  <section class="hero">
  <div class="hero-content">
    <div class="hero-text">
      <h2>Donate Blood, Save Lives</h2>
      <p>Every drop counts. Join our mission to give hope, health, and a second chance at life.</p>
      <div class="buttons">
        <a href="{% url 'donor-register' %}" class="primary-btn">Become a Donor</a>
        <a href="{% url 'login' %}" class="secondary-btn">Donor Login</a>
      </div>
    </div>
    <div class="hero-img">
      <img src="{% static 'img/hero.jpg' %}" alt="Blood donation illustration"/>
    </div>
  </div>
</section>

  <section class="about animate-fade-up" id="about">
    <h3>Why Your Blood Matters</h3>
    <!-- IMAGE/ILLUSTRATION PLACEHOLDER -->
    <div class="section-img">
      <img src="{% static 'img/banner2.jpg' %}" alt="Blood Donation Banner">
    </div>
    <p>Every 2 seconds, someone in the world needs blood. Your one donation can save up to three lives. Blood cannot be manufactured — it can only come from generous donors like you.</p>
  </section>
  <section class="how-it-works animate-fade-up" id="how">
    <h3>How It Works</h3>
    <p>It’s fast, simple, and safe to donate blood. Here’s how:</p>
    <div class="steps">
      <div class="step"><i class="uil uil-user-plus"></i><p>1. Register or log in</p></div>
      <div class="step"><i class="uil uil-medical-square"></i><p>2. Find a donation center</p></div>
      <div class="step"><i class="uil uil-heart-medical"></i><p>3. Donate & save lives</p></div>
    </div>
  </section>
  <section class="cta animate-fade-up">
    <h4>Ready to make an impact?</h4>
    <a href="{% url 'donor-register' %}">Register as a Donor</a>
  </section>
  <footer>
    &copy; 2025 BloodBank. Designed with ❤️ to save lives.
  </footer>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    // INTERSECTION OBSERVER – fade up on scroll
    const faders = document.querySelectorAll('.animate-fade-up');
    const observer = new window.IntersectionObserver(entries => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('in-view');
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.17 });
    faders.forEach(el => observer.observe(el));
  </script>
</body>
</html>
